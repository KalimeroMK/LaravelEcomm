# =============================================================================
# PRODUCTION ENVIRONMENT
# =============================================================================
# Копирај го овој фајл во .env.prod и пополни ги вредностите
# =============================================================================

APP_NAME="E-Comm MK"
APP_ENV=production
APP_KEY=base64:6hhGR9dehQ7+B861RJ0MaBYoAejcvntF9S3AX/8yHG4=
APP_DEBUG=false
APP_URL=https://e-comm.mk

# Клучно за работа зад Cloudflare!
TRUSTED_PROXIES=*

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

BROADCAST_DRIVER=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CLIENT=predis

# За продукција користи SMTP или друг сервис
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@e-comm.mk
MAIL_FROM_NAME="${APP_NAME}"

SCOUT_DRIVER=elastic
SCOUT_ELASTIC_HOST=elasticsearch:9200

# Cloudflare Tunnel Token (стави го во .env.prod)
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

TELESCOPE_ENABLED=false
DEBUGBAR_ENABLED=false

# =============================================================================
# BLAZE OPTIMIZATION (вклучи во продукција за брзина)
# =============================================================================
BLAZE_ENABLED=true
BLAZE_DEBUG=false
BLAZE_THROW=false
BLAZE_CACHE_WARM=true

# =============================================================================
# THEME
# =============================================================================
FRONT_ACTIVE_TEMPLATE=default
ACTIVE_TEMPLATE=default
